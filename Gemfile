source "https://rubygems.org"

# GitHub Pages-compatible Jekyll. Using the github-pages gem pins versions
# to match GitHub's own Pages build environment.
gem "jekyll", "~> 4.3"

# Windows and JRuby time-zone data (harmless elsewhere)
gem "tzinfo-data", platforms: [:mingw, :mswin, :x64_mingw, :jruby]

# Faster file watching on Windows during local `jekyll serve`
gem "wdm", "~> 0.1.1", platforms: [:mingw, :mswin, :x64_mingw]
